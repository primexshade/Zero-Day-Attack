# X-IDS Environment Configuration for Development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

# Security Configuration
JWT_SECRET=dev-secret-key-change-in-production
TLS_ENABLED=false
TLS_CERT_PATH=/etc/xids/certs/cert.pem
TLS_KEY_PATH=/etc/xids/certs/key.pem

# Data Configuration
MODEL_DIR=./data/models
LOG_DIR=./data/logs
DATA_DIR=./data

# Kafka Configuration
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=intrusion-detection
KAFKA_GROUP_ID=xids-consumer-dev
KAFKA_AUTO_OFFSET_RESET=earliest

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX=xids-alerts-dev

# Splunk Configuration (Optional)
SPLUNK_HOST=
SPLUNK_PORT=8088
SPLUNK_TOKEN=
SPLUNK_ENABLED=false

# Prometheus Configuration
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090

# Database Configuration (Optional)
DATABASE_URL=postgresql://xids:changeme@postgres:5432/x_ids_dev
DATABASE_ENABLED=false

# SIEM Configuration
SIEM_TYPE=elasticsearch
SIEM_HOST=elasticsearch
SIEM_PORT=9200

# Training Configuration
TRAINING_EPOCHS=10
TRAINING_BATCH_SIZE=32
TRAINING_TEST_SIZE=0.2
TRAINING_RANDOM_STATE=42

# Model Configuration
MODEL_TYPE=ensemble
ENSEMBLE_MODELS=autoencoder,tcn,random_forest
ENSEMBLE_WEIGHTS=0.33,0.33,0.34

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# Monitoring
MONITORING_ENABLED=true
METRICS_PORT=9090

# Environment
ENVIRONMENT=development
COMPANY=SecOps
PROJECT_NAME=X-IDS

# Features
FEATURE_KAFKA_STREAMING=true
FEATURE_ELASTICSEARCH_STORAGE=true
FEATURE_PROMETHEUS_METRICS=true
FEATURE_JWT_AUTH=false
FEATURE_TLS=false
